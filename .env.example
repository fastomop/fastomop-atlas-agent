# Azure OpenAI Configuration
# Get these values from your Azure OpenAI resource in the Azure Portal

# Your Azure OpenAI endpoint (e.g., https://your-resource-name.openai.azure.com/)
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/

# Your Azure OpenAI deployment name (the name you gave your deployment, not the model name)
AZURE_OPENAI_DEPLOYMENT=your-deployment-name

# Your Azure OpenAI API key (found in "Keys and Endpoint" section of your Azure resource)
AZURE_OPENAI_API_KEY=your-api-key-here

# Optional: Override model settings
# AZURE_OPENAI_API_VERSION=2025-01-01-preview

# OHDSI WebAPI Configuration (for OMOP vocabulary lookups)
# WEBAPI_URL=http://localhost:8080/WebAPI
# WEBAPI_CDM_SOURCE=MIMIC

# Optional: Ollama (if you want to keep it as fallback)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=gpt-oss:120b
